---
interface TeamMember {
  name: string;
  role: string;
  bio: string;
  image: string;
  linkedin?: string;
  github?: string;
  twitter?: string;
  portfolio?: string;
}

const team: TeamMember[] = [
  {
    name: "Wilman Montenegro",
    role: "Ingeniero de Sistemas",
    bio: "Desarrollo de software que resuelve problemas reales. Curioso, creativo y obsesionado con la calidad.",
    image: "/wilman-montenegro.png",
    linkedin: "https://www.linkedin.com/in/wilman-montenegro/",
    github: "https://github.com/wilmanmontenegro",
    twitter: "https://x.com/WilmanDev",
    portfolio: "https://wilman.dev",
  },
  {
    name: "Bernabe Aguilar",
    role: "Lic. en Administración de Empresas y Economía",
    bio: "Estrategia de negocios, análisis económico y transformación digital. Traduce procesos empresariales en datos e indicadores para decisiones estratégicas.",
    image: "",
    linkedin: "https://www.linkedin.com/in/bernabeaguilar/",
  },
];

const stats = [
  { value: "8+", label: "Años de experiencia" },
  { value: "50+", label: "Proyectos completados" },
  { value: "30+", label: "Clientes satisfechos" },
  { value: "100%", label: "Compromiso" },
];
---

<section id="equipo" class="bg-brand-text px-6 py-16 text-brand-bg md:py-24">
  <div class="mx-auto max-w-6xl">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-xs font-bold uppercase tracking-[0.28em] text-ruby">Nuestro equipo</p>
      <h2 class="mt-4 text-2xl font-bold leading-tight sm:text-3xl md:text-4xl">
        Personas que hacen posible tu proyecto
      </h2>
      <p class="mt-4 text-base leading-relaxed text-brand-bg md:text-lg">
        Un equipo multidisciplinario comprometido con entregar soluciones tecnológicas de alta calidad.
      </p>
    </div>

    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-2">
      {team.map((member) => (
        <article class="group relative rounded-2xl border border-ruby/20 bg-brand-text p-8 transition-all duration-300 hover:border-ruby/50 hover:shadow-[0_0_40px_rgba(192,18,46,0.2)] hover:-translate-y-1">
          <div class="flex flex-col items-center text-center">
            <div class="relative mb-6">
              <div class="absolute inset-0 rounded-full bg-ruby/20 blur-[10px] opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              <img
                src={member.image}
                alt={member.name}
                width="120"
                height="120"
                loading="lazy"
                decoding="async"
                class="relative z-10 h-[120px] w-[120px] rounded-full object-cover object-top border-2 border-ruby/30"
              />
            </div>
            
            <h3 class="text-xl font-bold text-brand-bg">{member.name}</h3>
            <p class="mt-2 text-sm font-semibold uppercase tracking-wider text-ruby">{member.role}</p>
            <p class="mt-4 text-base leading-relaxed text-brand-bg">{member.bio}</p>
            
            <div class="mt-6 flex flex-wrap justify-center gap-3">
              {member.linkedin && (
                <a 
                  href={member.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`LinkedIn de ${member.name}`}
                  class="flex h-10 w-10 items-center justify-center rounded-lg bg-ruby/10 border border-ruby/30 text-ruby transition-all duration-200 hover:bg-ruby hover:text-white"
                >
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
              )}
              {member.github && (
                <a 
                  href={member.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`GitHub de ${member.name}`}
                  class="flex h-10 w-10 items-center justify-center rounded-lg bg-ruby/10 border border-ruby/30 text-ruby transition-all duration-200 hover:bg-ruby hover:text-white"
                >
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                  </svg>
                </a>
              )}
              {member.twitter && (
                <a 
                  href={member.twitter}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`X de ${member.name}`}
                  class="flex h-10 w-10 items-center justify-center rounded-lg bg-ruby/10 border border-ruby/30 text-ruby transition-all duration-200 hover:bg-ruby hover:text-white"
                >
                  <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                  </svg>
                </a>
              )}
              {member.portfolio && (
                <a 
                  href={member.portfolio}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`Portafolio de ${member.name}`}
                  class="flex h-10 w-10 items-center justify-center rounded-lg bg-ruby/10 border border-ruby/30 text-ruby transition-all duration-200 hover:bg-ruby hover:text-white"
                >
                  <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-2">
      {stats.map((stat) => (
        <div class="rounded-xl border border-ruby/30 bg-ruby/10 p-6 text-center">
          <p class="text-3xl font-bold text-ruby">{stat.value}</p>
          <p class="mt-2 text-xs font-semibold uppercase tracking-wider text-brand-bg">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
