---
---
<header class="fixed inset-x-0 top-0 z-30 pointer-events-none">
  <nav id="site-nav" class="nav-shell mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-5 text-hero-text pointer-events-auto">
    <a href={import.meta.env.BASE_URL} class="flex items-center gap-3">
      <img src={`${import.meta.env.BASE_URL}/logo.png`} alt="Logo Catalyx Group" class="nav-logo h-16 w-auto object-contain" loading="eager" decoding="async" />
      <span class="text-sm font-semibold tracking-[0.18em] text-hero-text md:text-base">CATALYX GROUP S.A.S</span>
    </a>

    <ul class="hidden items-center gap-8 text-sm font-medium text-hero-muted md:flex">
      <li><a href="#inicio" class="transition hover:text-hero-text">Inicio</a></li>
      <li><a href="#servicios" class="transition hover:text-hero-text">Servicios</a></li>
      <li><a href="#nosotros" class="transition hover:text-hero-text">Sobre nosotros</a></li>
      <li><a href="#contacto" class="transition hover:text-hero-text">Contacto</a></li>
    </ul>

    <div class="flex items-center gap-3">
      <button
        id="theme-toggle"
        type="button"
        aria-label="Cambiar tema"
        title="Cambiar tema"
        class="rounded-lg border border-ruby/70 bg-ruby/10 p-2.5 text-hero-text transition hover:bg-ruby/20"
      >
        <svg id="icon-sun" viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true">
          <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8" />
          <path d="M12 2V4.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          <path d="M12 19.5V22" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          <path d="M4.93 4.93L6.7 6.7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          <path d="M17.3 17.3L19.07 19.07" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          <path d="M2 12H4.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          <path d="M19.5 12H22" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          <path d="M4.93 19.07L6.7 17.3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
          <path d="M17.3 6.7L19.07 4.93" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
        </svg>

        <svg id="icon-moon" viewBox="0 0 24 24" fill="none" class="hidden h-5 w-5" aria-hidden="true">
          <path
            d="M20 14.2C19.2 14.5 18.4 14.7 17.5 14.7C13.5 14.7 10.3 11.5 10.3 7.5C10.3 6.6 10.5 5.8 10.8 5C7.4 5.6 4.8 8.6 4.8 12.2C4.8 16.2 8 19.4 12 19.4C15.6 19.4 18.6 16.8 20 13.4V14.2Z"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </button>

      <a href="#contacto" class="hidden rounded-lg border border-ruby px-4 py-2 text-sm font-semibold text-hero-text transition hover:bg-ruby md:inline-flex">Agenda una reunión</a>

      <button
        id="menu-toggle"
        type="button"
        aria-label="Abrir menú"
        class="rounded-lg border border-ruby/70 bg-ruby/10 p-2.5 text-hero-text transition hover:bg-ruby/20 md:hidden"
      >
        <svg id="icon-hamburger" viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true">
          <path d="M4 6H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <path d="M4 12H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <path d="M4 18H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
        <svg id="icon-close-menu" viewBox="0 0 24 24" fill="none" class="hidden h-5 w-5" aria-hidden="true">
          <path d="M6 6L18 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          <path d="M18 6L6 18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
  </nav>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 z-20 flex flex-col items-center justify-center bg-brand-text opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
  aria-hidden="true"
>
  <nav class="flex flex-col items-center gap-8 text-center">
    <a href="#inicio" class="mobile-nav-link text-2xl font-semibold tracking-wide text-brand-bg transition hover:text-ruby">Inicio</a>
    <a href="#servicios" class="mobile-nav-link text-2xl font-semibold tracking-wide text-brand-bg transition hover:text-ruby">Servicios</a>
    <a href="#nosotros" class="mobile-nav-link text-2xl font-semibold tracking-wide text-brand-bg transition hover:text-ruby">Sobre nosotros</a>
    <a href="#contacto" class="mobile-nav-link text-2xl font-semibold tracking-wide text-brand-bg transition hover:text-ruby">Contacto</a>
    <a href="#contacto" class="mobile-nav-link mt-4 rounded-lg bg-ruby px-8 py-3 text-base font-semibold text-hero-text transition hover:bg-ruby-bright">Agenda una reunión</a>
  </nav>
</div>

<script is:inline>
  (() => {
    const toggle = document.getElementById('theme-toggle');
    const sun = document.getElementById('icon-sun');
    const moon = document.getElementById('icon-moon');
    const nav = document.getElementById('site-nav');
    if (!toggle || !nav) return;

    const setToggleState = () => {
      const isDark = document.documentElement.classList.contains('theme-dark');
      if (sun) sun.classList.toggle('hidden', isDark);
      if (moon) moon.classList.toggle('hidden', !isDark);
      toggle.setAttribute('aria-label', isDark ? 'Cambiar a modo claro' : 'Cambiar a modo oscuro');
      toggle.setAttribute('title', isDark ? 'Cambiar a modo claro' : 'Cambiar a modo oscuro');
    };

    setToggleState();

    const setScrollState = () => {
      nav.classList.toggle('nav-shell--scrolled', window.scrollY > 14);
    };

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        setScrollState();
        ticking = false;
      });
    };

    const previousState = window.__catalyxHeaderState;
    if (previousState?.onScroll) {
      window.removeEventListener('scroll', previousState.onScroll);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.__catalyxHeaderState = { onScroll };
    setScrollState();

    if (!toggle.dataset.boundThemeToggle) {
      toggle.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('theme-dark');
        localStorage.setItem('theme-mode', isDark ? 'dark' : 'light');
        setToggleState();
      });
      toggle.dataset.boundThemeToggle = 'true';
    }
  })();

  (() => {
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconHamburger = document.getElementById('icon-hamburger');
    const iconCloseMenu = document.getElementById('icon-close-menu');
    if (!menuToggle || !mobileMenu) return;

    const openMenu = () => {
      mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
      mobileMenu.classList.add('opacity-100');
      mobileMenu.setAttribute('aria-hidden', 'false');
      iconHamburger?.classList.add('hidden');
      iconCloseMenu?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      menuToggle.setAttribute('aria-label', 'Cerrar menú');
    };

    const closeMenu = () => {
      mobileMenu.classList.add('opacity-0', 'pointer-events-none');
      mobileMenu.classList.remove('opacity-100');
      mobileMenu.setAttribute('aria-hidden', 'true');
      iconHamburger?.classList.remove('hidden');
      iconCloseMenu?.classList.add('hidden');
      document.body.style.overflow = '';
      menuToggle.setAttribute('aria-label', 'Abrir menú');
    };

    if (!menuToggle.dataset.boundMenuToggle) {
      menuToggle.addEventListener('click', () => {
        const isOpen = !mobileMenu.classList.contains('opacity-0');
        isOpen ? closeMenu() : openMenu();
      });

      document.querySelectorAll('.mobile-nav-link').forEach(link => {
        link.addEventListener('click', closeMenu);
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeMenu();
      });

      menuToggle.dataset.boundMenuToggle = 'true';
    }
  })();
</script>